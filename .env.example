# ==========================================================================
# CRE Workflow Simulation Environment Variables
# ==========================================================================
# Copy to .env and fill in your values.
# The simulate-all.sh script auto-exports placeholders, but real values
# are needed for full end-to-end verification.

# ── Deployer Wallet (Sepolia testnet ONLY) ────────────────────────────────
CRE_ETH_PRIVATE_KEY=0x<your-sepolia-deployer-private-key>

# ── Supabase (escrow-*, invoice-settle, payroll-attest, report-verify) ────
SUPABASE_URL_VAR=https://<your-project>.supabase.co
SUPABASE_SERVICE_KEY_VAR=eyJ<your-service-role-key>

# ── Shiva API (escrow-dispute, escrow-finalize, escrow-verify) ────────────
SHIVA_API_URL_VAR=https://<your-shiva-url>
SHIVA_SERVICE_TOKEN_VAR=<your-shiva-service-token>
SHIVA_URL_VAR=https://<your-shiva-url>
SHIVA_API_KEY_VAR=<your-shiva-api-key>

# ── ACE / Ghost Mode (ghost-*, private-transfer, allowlist-sync) ──────────
ACE_API_KEY_VAR=<your-ace-api-key>
ACE_URL_VAR=https://<your-ace-url>

# ── Motora (escrow-yield) ─────────────────────────────────────────────────
MOTORA_API_URL_VAR=https://<your-motora-url>
MOTORA_API_KEY_VAR=<your-motora-api-key>
MOTORA_URL_VAR=https://<your-motora-url>
