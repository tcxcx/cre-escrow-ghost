{
  "name": "i-hate-lawyers-and-bankers",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/cre/ai-escrow/workflow",
    "packages/cre/stable-fx/workflow",
    "packages/cre/bufi-lifecycle/workflow",
    "hardhat"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "compile": "turbo run compile",
    "test": "turbo run test",

    "docs:dev": "turbo run dev --filter=docs",
    "docs:build": "turbo run build --filter=docs",
    "docs:lint": "turbo run lint --filter=docs",
    "docs:check-types": "turbo run check-types --filter=docs",

    "api:dev": "turbo run dev --filter=api",
    "api:build": "turbo run build --filter=api",
    "api:deploy": "turbo run deploy --filter=api",
    "api:check-types": "turbo run check-types --filter=api",

    "contracts:build": "turbo run build --filter=@repo/contracts",
    "contracts:compile": "turbo run compile --filter=@repo/contracts",
    "contracts:dev": "turbo run dev --filter=@repo/contracts",
    "contracts:test": "turbo run test --filter=@repo/contracts",

    "ui:lint": "turbo run lint --filter=@repo/ui",
    "ui:check-types": "turbo run check-types --filter=@repo/ui",

    "cre:login": "~/.cre/bin/cre login",
    "cre:whoami": "~/.cre/bin/cre whoami",
    "cre:init": "~/.cre/bin/cre init",
    "cre:account:link-key": "~/.cre/bin/cre account link-key",
    "cre:account:list-key": "~/.cre/bin/cre account list-key",
    "cre:account:unlink-key": "~/.cre/bin/cre account unlink-key",

    "ai-escrow:simulate": "turbo run cre:workflow:simulate --filter=@repo/cre-ai-escrow",
    "ai-escrow:deploy": "turbo run cre:workflow:deploy --filter=@repo/cre-ai-escrow",
    "ai-escrow:activate": "turbo run cre:workflow:activate --filter=@repo/cre-ai-escrow",
    "ai-escrow:pause": "turbo run cre:workflow:pause --filter=@repo/cre-ai-escrow",
    "ai-escrow:delete": "turbo run cre:workflow:delete --filter=@repo/cre-ai-escrow",
    "ai-escrow:secrets:create": "turbo run cre:secrets:create --filter=@repo/cre-ai-escrow",
    "ai-escrow:secrets:update": "turbo run cre:secrets:update --filter=@repo/cre-ai-escrow",
    "ai-escrow:secrets:list": "turbo run cre:secrets:list --filter=@repo/cre-ai-escrow",
    "ai-escrow:secrets:delete": "turbo run cre:secrets:delete --filter=@repo/cre-ai-escrow",
    "ai-escrow:bindings": "turbo run cre:bindings --filter=@repo/cre-ai-escrow",

    "stable-fx:simulate": "turbo run cre:workflow:simulate --filter=@repo/cre-stable-fx",
    "stable-fx:deploy": "turbo run cre:workflow:deploy --filter=@repo/cre-stable-fx",
    "stable-fx:activate": "turbo run cre:workflow:activate --filter=@repo/cre-stable-fx",
    "stable-fx:pause": "turbo run cre:workflow:pause --filter=@repo/cre-stable-fx",
    "stable-fx:delete": "turbo run cre:workflow:delete --filter=@repo/cre-stable-fx",
    "stable-fx:secrets:create": "turbo run cre:secrets:create --filter=@repo/cre-stable-fx",
    "stable-fx:secrets:update": "turbo run cre:secrets:update --filter=@repo/cre-stable-fx",
    "stable-fx:secrets:list": "turbo run cre:secrets:list --filter=@repo/cre-stable-fx",
    "stable-fx:secrets:delete": "turbo run cre:secrets:delete --filter=@repo/cre-stable-fx",
    "stable-fx:bindings": "turbo run cre:bindings --filter=@repo/cre-stable-fx",

    "bufi:simulate": "turbo run cre:workflow:simulate --filter=@repo/cre-bufi-lifecycle",
    "bufi:deploy": "turbo run cre:workflow:deploy --filter=@repo/cre-bufi-lifecycle",
    "bufi:activate": "turbo run cre:workflow:activate --filter=@repo/cre-bufi-lifecycle",
    "bufi:pause": "turbo run cre:workflow:pause --filter=@repo/cre-bufi-lifecycle",
    "bufi:secrets:create": "turbo run cre:secrets:create --filter=@repo/cre-bufi-lifecycle",
    "bufi:secrets:list": "turbo run cre:secrets:list --filter=@repo/cre-bufi-lifecycle"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.1",
    "typescript": "5.9.2"
  },
  "packageManager": "bun@1.2.13",
  "engines": {
    "node": ">=18"
  },
  "trustedDependencies": [
    "@arbitrum/nitro-contracts"
  ]
}
