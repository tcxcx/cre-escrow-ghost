{
  "name": "@repo/contracts",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "hardhat compile && hardhat compile --config hardhat.bufi.config.ts",
    "compile": "hardhat compile && hardhat compile --config hardhat.bufi.config.ts",
    "compile:router": "hardhat compile",
    "compile:bufi": "hardhat compile --config hardhat.bufi.config.ts",
    "dev": "hardhat node",
    "test": "hardhat test",
    "test:bufi": "hardhat test --config hardhat.bufi.config.ts",
    "test:fork": "hardhat test --grep 'Fork'",
    "test:no-fork": "hardhat test --grep '^(?!.*Fork).*$'",
    "lint": "echo 'no lint configured'",
    "check-types": "hardhat compile && hardhat compile --config hardhat.bufi.config.ts"
  },
  "devDependencies": {
    "@chainlink/contracts": "1.5.0",
    "@chainlink/contracts-ccip": "1.6.2",
    "@chainlink/env-enc": "^1.0.5",
    "@chainlink/local": "0.2.7-beta.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.7",
    "@openzeppelin/contracts": "^4.7.3",
    "hardhat-preprocessor": "^0.1.5",
    "typescript": "^5.6.2"
  }
}
