# =============================================================================
# Ghost Mode Contracts — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# Deployer wallet (use a testnet burner wallet)
PRIVATE_KEY=0x...

# RPC endpoint (Sepolia)
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Already-deployed PolicyEngine proxy
POLICY_ENGINE_ADDRESS=0x806DD4d26A0930d4bEd506B81eb8f57F334Cd53e

# Initial USDC liquidity to escrow + mint backed USDg (whole units, min 1)
# USDg is NEVER minted without 1:1 USDC behind it.
# Set to 0 to deploy contracts only (no liquidity seeded).
INITIAL_DEPOSIT=0

# Circle DCW (for treasury wallet creation)
CIRCLE_API_KEY=TEST_API_KEY:...
CIRCLE_ENTITY_SECRET=...

# Shiva API (for wallet creation endpoint)
SHIVA_URL=http://localhost:8787
SHIVA_JWT=eyJ...

# Chain ID (11155111 = Sepolia, 1 = Mainnet)
CHAIN_ID=11155111
